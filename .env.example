# Database — Postgres connection string.
# Default: Supabase free-tier project (recommended; avoids Docker on Windows).
# Fallback: local Docker via `pnpm db:up` then point this at postgres://chanakya:chanakya@localhost:5433/chanakya
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/chanakya?sslmode=require"

# NextAuth — generate with `openssl rand -hex 32`
NEXTAUTH_SECRET="change-me-in-prod"
NEXTAUTH_URL="http://localhost:3000"
AUTH_PROVIDERS="credentials"

# AI engine selector: 'scripted' (V1, hand-tuned responses) | 'llm' (V2, not built yet)
CHANAKYA_AI_ENGINE="scripted"

# Logging
LOG_LEVEL="info"
NODE_ENV="development"
